{
  "name": "call-booking-service-typespec",
  "version": "1.0.0",
  "scripts": {
    "start": "node --import tsx backend/server.ts",
    "test": "TZ=UTC node --import tsx --test test/backend.test.ts",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit",
    "build:backend": "tsc -p tsconfig.build.json",
    "typespec:compile": "tsp compile ./typespec/main.tsp --emit @typespec/openapi3",
    "prism:mock": "prism mock tsp-output/@typespec/openapi3/openapi.yaml",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "playwright:install": "playwright install",
    "test:e2e": "TZ=UTC playwright test",
    "test:e2e:ui": "TZ=UTC playwright test --ui",
    "test:e2e:headed": "TZ=UTC playwright test --headed"
  },
  "dependencies": {
    "@fastify/static": "^9.1.0",
    "@typespec/compiler": "^1.10.0",
    "@typespec/http": "^1.10.0",
    "@typespec/openapi3": "^1.10.0",
    "@typespec/rest": "^0.80.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@stoplight/prism-cli": "^5.14.2",
    "@types/node": "^24.7.2",
    "shadcn": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
